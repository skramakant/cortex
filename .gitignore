# ============================================================
# Dependencies
# ============================================================
node_modules/
**/node_modules/

# ============================================================
# Build output
# Generated by CI (GitHub Actions) — do not commit manually.
# ============================================================
frontend/public/css/app.css

# ============================================================
# Secrets and environment variables
# ============================================================
.env
.env.local
.env.*.local
*.env
# Never commit a version of api.js with the real GAS URL injected
# (the placeholder __GAS_URL__ version is safe to commit)

# ============================================================
# Lock files (keep tests lock, skip frontend lock — CI uses npm ci)
# ============================================================
# tests/package-lock.json is intentionally tracked for reproducible CI

# ============================================================
# macOS
# ============================================================
.DS_Store
**/.DS_Store
.AppleDouble
.LSOverride

