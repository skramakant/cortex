# Editor and IDE
# ============================================================
.vscode/settings.json
.vscode/launch.json
.vscode/*.code-workspace
.idea/
*.swp
*.swo
*~

# ============================================================
# Logs
# ============================================================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
*.log

# ============================================================
# Test coverage and reports
# ============================================================
coverage/
.nyc_output/
*.lcov

# ============================================================
