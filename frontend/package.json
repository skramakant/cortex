{
  "name": "tweetgen-frontend",
  "version": "1.0.0",
  "description": "Tweet Scheduler — static frontend hosted on GitHub Pages",
  "private": true,
  "scripts": {
    "build:css": "tailwindcss -i ./src/css/input.css -o ./public/css/app.css --minify",
    "build:js": "node scripts/inject-env.js",
    "build": "npm run build:css && npm run build:js",
    "dev": "tailwindcss -i ./src/css/input.css -o ./public/css/app.css --watch"
  },
  "devDependencies": {
    "tailwindcss": "3.4.1"
  }
}
