{
  "name": "tweet-resource-extractor-tests",
  "version": "1.0.0",
  "description": "Node.js-based tests for the Tweet Resource Extractor Google Apps Script",
  "scripts": {
    "test": "node --experimental-vm-modules node_modules/.bin/jest --testPathPattern='tests/'",
    "test:unit": "node --experimental-vm-modules node_modules/.bin/jest --testPathPattern='tests/unit'",
    "test:property": "node --experimental-vm-modules node_modules/.bin/jest --testPathPattern='tests/property'"
  },
  "devDependencies": {
    "fast-check": "^3.15.0",
    "jest": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/*.test.js"
    ]
  }
}
